GOOGLE_API_KEY=your_google_api_key_here
# Optional comma-separated multi-key router. Keep real values only in .env.
GOOGLE_API_KEYS=key_a,key_b,key_c,key_d
ENABLE_LLM=true
GEMINI_MODEL_SEQUENCE=gemini-2.5-flash,gemini-flash-latest

# Optional API hardening. Leave PARKING_API_KEY blank for local demos.
PARKING_API_KEY=
PARKING_ALLOWED_ORIGINS=http://127.0.0.1:8501,http://localhost:8501,http://127.0.0.1:5173,http://localhost:5173
